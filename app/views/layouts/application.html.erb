    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-900 text-white min-h-screen font-sans" style="font-family: 'Plus Jakarta Sans', sans-serif;">
    <%= yield %>
    <%= render "shared/footer" %>
  </body>
</html>
